{
  "name": "deskit-plugin-timestamp",
  "version": "0.2.0",
  "private": true,
  "description": "Timestamp converter plugin for DesKit",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node22 --outfile=dist/index.js",
    "validate": "node scripts/validate-manifest.mjs",
    "pack": "node scripts/pack-deskit.mjs",
    "check": "npm run typecheck && npm run build && npm run validate"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "archiver": "^7.0.1",
    "esbuild": "^0.21.5",
    "typescript": "^5.9.3"
  }
}
