{
  "$schema": "./schema/deskit-manifest.schema.json",
  "id": "com.deskit.timestamp",
  "name": "timestamp",
  "displayName": {
    "en": "Timestamp Converter",
    "zh-CN": "时间戳转换"
  },
  "description": {
    "en": "Convert between Unix timestamps and readable dates.",
    "zh-CN": "在 Unix 时间戳和可读日期之间相互转换。"
  },
  "version": "0.2.0",
  "author": "DesKit",
  "engines": { "deskit": "^0.2.0" },
  "main": "dist/index.js",
  "contributes": {
    "commands": [
      {
        "id": "timestamp.convert",
        "title": {
          "en": "Convert Timestamp",
          "zh-CN": "转换时间戳"
        },
        "subtitle": {
          "en": "Seconds, milliseconds, dates, and time zones",
          "zh-CN": "支持秒、毫秒、日期和时区"
        },
        "keywords": [
          "timestamp",
          "time",
          "date",
          "unix",
          "epoch",
          "ts",
          "时间戳",
          "日期",
          "时间"
        ],
        "mode": "view"
      }
    ],
    "preferences": [
      {
        "id": "timestampUnit",
        "type": "select",
        "label": {
          "en": "Input timestamp unit",
          "zh-CN": "输入时间戳单位"
        },
        "default": "auto",
        "options": [
          {
            "value": "auto",
            "label": {
              "en": "Auto detect",
              "zh-CN": "自动识别"
            }
          },
          {
            "value": "seconds",
            "label": {
              "en": "Seconds",
              "zh-CN": "秒"
            }
          },
          {
            "value": "milliseconds",
            "label": {
              "en": "Milliseconds",
              "zh-CN": "毫秒"
            }
          }
        ]
      },
      {
        "id": "defaultTimeZone",
        "type": "select",
        "label": {
          "en": "Default time zone",
          "zh-CN": "默认时区"
        },
        "default": "local",
        "options": [
          {
            "value": "local",
            "label": {
              "en": "System local time",
              "zh-CN": "系统本地时间"
            }
          },
          {
            "value": "UTC",
            "label": "UTC"
          },
          {
            "value": "Asia/Shanghai",
            "label": {
              "en": "Asia/Shanghai",
              "zh-CN": "亚洲/上海"
            }
          },
          {
            "value": "America/New_York",
            "label": {
              "en": "America/New York",
              "zh-CN": "美洲/纽约"
            }
          },
          {
            "value": "Europe/London",
            "label": {
              "en": "Europe/London",
              "zh-CN": "欧洲/伦敦"
            }
          },
          {
            "value": "Asia/Tokyo",
            "label": {
              "en": "Asia/Tokyo",
              "zh-CN": "亚洲/东京"
            }
          }
        ]
      }
    ]
  },
  "permissions": []
}
